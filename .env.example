# Runtime AI provider defaults (GBits internal proxy first)
RUNTIME_IMAGE_PROVIDER=proxy

# GBits AIServiceProxy
AISERVICEPROXY_BASE_URL=http://aitools.g-bits.com/aiserviceproxy
AISERVICEPROXY_IMAGE_MODEL=banana-pro
AISERVICEPROXY_FALLBACK_IMAGE_MODELS=gemini-3-pro
AISERVICEPROXY_TIMEOUT_MS=120000

# Set your secret only in .env.local or OS env (do not commit)
AISERVICEPROXY_API_KEY=YOUR_AISERVICEPROXY_KEY

# Optional Gemini fallback
# GEMINI_API_KEY=YOUR_GEMINI_KEY
# GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview
